@* Icing Zoom: First week of January - Temp vs Dew Point *@

@if (Result != null)
{
    <ApexChart TItem="XYPoint" Options="_options" Height="400" XAxisType="XAxisType.Numeric" @ref="_chart">
        <ApexPointSeries TItem="XYPoint"
                         Items="_tempData"
                         Name="Temperatur"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
        <ApexPointSeries TItem="XYPoint"
                         Items="_dewData"
                         Name="Taupunkt"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
    </ApexChart>
}

@code {
    [Parameter] public SimulationResult? Result { get; set; }

    private ApexChart<XYPoint>? _chart;
    private ApexChartOptions<XYPoint> _options = new();
    private List<XYPoint> _tempData = [];
    private List<XYPoint> _dewData = [];
    private bool _dataChanged;
    private SimulationResult? _prev;

    protected override void OnParametersSet()
    {
        if (Result == null || Result == _prev) return;
        _prev = Result;

        _tempData = [];
        _dewData = [];
        int hours = Math.Min(168, Result.Temperature.Length);
        for (int i = 0; i < hours; i++)
        {
            _tempData.Add(new XYPoint(i, Result.Temperature[i]));
            _dewData.Add(new XYPoint(i, Result.DewPoint[i]));
        }

        _options = new ApexChartOptions<XYPoint>
        {
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Title = new Title { Text = "Januar Woche (Temp vs Taupunkt)" },
            Xaxis = new XAxis { Title = new AxisTitle { Text = "Stunde" } },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = "°C" }, Labels = new YAxisLabels { Formatter = @"function(val) { return val.toFixed(1); }" } }],
            Colors = ["#2563eb", "#9ca3af"],
            Stroke = new Stroke { Width = new List<double> { 2, 2 }, DashArray = new List<double> { 0, 4 } },
            Legend = new Legend { Position = LegendPosition.Bottom },
            Tooltip = new Tooltip { Enabled = true, Y = new TooltipY { Formatter = @"function(val) { return val.toFixed(1); }" } }
        };
        _dataChanged = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _dataChanged && _chart != null)
        {
            _dataChanged = false;
            await _chart.RenderAsync();
        }
    }
}
