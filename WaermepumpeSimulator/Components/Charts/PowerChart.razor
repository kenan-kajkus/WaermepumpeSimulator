@* Power profile: Load vs Min + cycling markers *@

@if (Result != null)
{
    <ApexChart TItem="XYPoint" Options="_options" Height="400" XAxisType="XAxisType.Numeric" @ref="_chart">
        <ApexPointSeries TItem="XYPoint"
                         Items="_loadData"
                         Name="Last (24h)"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
        <ApexPointSeries TItem="XYPoint"
                         Items="_minData"
                         Name="Min. Leistung"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
        @if (_taktData.Count > 0)
        {
            <ApexPointSeries TItem="XYPoint"
                             Items="_taktData"
                             Name="Taktung"
                             SeriesType="SeriesType.Scatter"
                             XValue="p => p.X"
                             YValue="p => p.Y" />
        }
    </ApexChart>
}

@code {
    [Parameter] public SimulationResult? Result { get; set; }

    private ApexChart<XYPoint>? _chart;
    private ApexChartOptions<XYPoint> _options = new();
    private List<XYPoint> _loadData = [];
    private List<XYPoint> _minData = [];
    private List<XYPoint> _taktData = [];
    private bool _dataChanged;
    private SimulationResult? _prev;

    protected override void OnParametersSet()
    {
        if (Result == null || Result == _prev) return;
        _prev = Result;
        var r = Result;
        var rollL = RollingAvg(r.Load, 24);
        var rollMin = RollingAvg(r.MinPowerAvailable, 24);

        _loadData = [];
        _minData = [];
        _taktData = [];

        for (int i = 0; i < 8760; i += 6)
        {
            _loadData.Add(new XYPoint(i, rollL[i]));
            _minData.Add(new XYPoint(i, rollMin[i]));
        }

        for (int i = 0; i < 8760; i += 12)
            if (r.Cycling[i] == 1)
                _taktData.Add(new XYPoint(i, r.Load[i]));

        _options = new ApexChartOptions<XYPoint>
        {
            Chart = new Chart { Toolbar = new Toolbar { Show = false }, Zoom = new Zoom { Enabled = false } },
            Title = new Title { Text = "Verlauf & Taktung" },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels { Formatter = @"function(val) { var m=['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez']; var h=[0,744,1416,2160,2880,3624,4344,5088,5832,6552,7296,8016]; for(var i=11;i>=0;i--){if(val>=h[i])return m[i];} return ''; }" },
                TickAmount = 12
            },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = "kW" }, Labels = new YAxisLabels { Formatter = @"function(val) { return val.toFixed(1); }" } }],
            Colors = ["#1f2937", "#9ca3af", "#dc2626"],
            Stroke = new Stroke { Width = new List<double> { 2, 2, 0 }, DashArray = new List<double> { 0, 4, 0 } },
            Markers = new Markers { Size = new List<double> { 0, 0, 3 } },
            Legend = new Legend { Position = LegendPosition.Bottom },
            Tooltip = new Tooltip
            {
                Enabled = true,
                Y = new TooltipY { Formatter = @"function(val) { return val.toFixed(1); }" },
                X = new TooltipX { Formatter = @"function(val) { var d=[31,28,31,30,31,30,31,31,30,31,30,31]; var m=['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez']; var h=Math.floor(val); var mo=0; while(mo<11 && h>=d[mo]*24){h-=d[mo]*24;mo++;} var tag=Math.floor(h/24)+1; var std=h%24; return tag+'. '+m[mo]+', '+std+':00'; }" }
            }
        };
        _dataChanged = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _dataChanged && _chart != null)
        {
            _dataChanged = false;
            await _chart.RenderAsync();
        }
    }

    private static double[] RollingAvg(double[] arr, int window)
    {
        var result = new double[arr.Length];
        double sum = 0; int count = 0;
        for (int i = 0; i < arr.Length; i++)
        {
            sum += arr[i]; count++;
            if (count > window) { sum -= arr[i - window]; count--; }
            result[i] = sum / count;
        }
        return result;
    }
}
