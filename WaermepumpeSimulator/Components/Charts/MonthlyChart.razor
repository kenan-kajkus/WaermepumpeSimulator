@* Monthly bar chart: Wärme vs Strom per month *@

@if (Monthly != null)
{
    <ApexChart TItem="MonthlyChartPoint" Options="_options" Height="500" @ref="_chart">
        <ApexPointSeries TItem="MonthlyChartPoint"
                         Items="_data"
                         Name="Wärme (kWh)"
                         SeriesType="SeriesType.Bar"
                         XValue="p => p.Month"
                         YAggregate="p => p.Sum(x => x.Waerme)" />
        <ApexPointSeries TItem="MonthlyChartPoint"
                         Items="_data"
                         Name="Strom (kWh)"
                         SeriesType="SeriesType.Bar"
                         XValue="p => p.Month"
                         YAggregate="p => p.Sum(x => x.Strom)" />
    </ApexChart>
}

@code {
    [Parameter] public List<MonthlyAggregate>? Monthly { get; set; }

    private ApexChart<MonthlyChartPoint>? _chart;
    private ApexChartOptions<MonthlyChartPoint> _options = new();
    private List<MonthlyChartPoint> _data = [];
    private bool _dataChanged;

    protected override void OnParametersSet()
    {
        if (Monthly == null) return;

        _data = Monthly.Select(m => new MonthlyChartPoint
        {
            Month = m.Name,
            Waerme = (decimal)Math.Round(m.Waerme, 1),
            Strom = (decimal)Math.Round(m.Strom, 1)
        }).ToList();

        _options = new ApexChartOptions<MonthlyChartPoint>
        {
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Title = new Title { Text = "Monatsbilanz" },
            PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false, ColumnWidth = "60%" } },
            Colors = ["#3b82f6", "#f97316"],
            Legend = new Legend { Position = LegendPosition.Bottom },
            Yaxis = [new YAxis { Labels = new YAxisLabels { Formatter = @"function(val) { return val.toFixed(0); }" } }],
            Tooltip = new Tooltip { Enabled = true, Y = new TooltipY { Formatter = @"function(val) { return val.toFixed(0); }" } }
        };
        _dataChanged = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _dataChanged && _chart != null)
        {
            _dataChanged = false;
            await _chart.RenderAsync();
        }
    }
}
