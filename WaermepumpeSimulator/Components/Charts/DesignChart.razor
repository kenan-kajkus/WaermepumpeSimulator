@* Härtetest: Leistung vs. Heizlast *@

@if (Result != null)
{
    <ApexChart TItem="XYPoint" Options="_options" Height="320" XAxisType="XAxisType.Numeric" @ref="_chart">
        <ApexPointSeries TItem="XYPoint"
                         Items="_demandLine"
                         Name="Bedarf Haus"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
        <ApexPointSeries TItem="XYPoint"
                         Items="_wpLine"
                         Name="Leistung WP (Max)"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
        <ApexPointSeries TItem="XYPoint"
                         Items="_wpPlusStab"
                         Name="WP + Heizstab"
                         SeriesType="SeriesType.Line"
                         XValue="p => p.X"
                         YValue="p => p.Y" />
    </ApexChart>
}

@code {
    [Parameter] public SimulationResult? Result { get; set; }
    [Parameter] public double HeizstabMax { get; set; }

    private ApexChart<XYPoint>? _chart;
    private ApexChartOptions<XYPoint> _options = new();
    private List<XYPoint> _demandLine = [];
    private List<XYPoint> _wpLine = [];
    private List<XYPoint> _wpPlusStab = [];

    private bool _dataChanged;

    protected override void OnParametersSet()
    {
        if (Result == null) return;
        var r = Result;

        _demandLine = [new(r.DesignTemperature, r.LoadAtDesignTemp), new(r.HeatingLimitTemperature, r.WarmwaterBaseLoad)];

        _wpLine = [];
        _wpPlusStab = [];
        for (int i = 0; i < r.LookupTemperatures.Length; i += 5)
        {
            _wpLine.Add(new(r.LookupTemperatures[i], r.PowerMaxAdjusted[i]));
            _wpPlusStab.Add(new(r.LookupTemperatures[i], r.PowerMaxAdjusted[i] + HeizstabMax));
        }

        _options = new ApexChartOptions<XYPoint>
        {
            Chart = new Chart { Toolbar = new Toolbar { Show = false } },
            Xaxis = new XAxis { Title = new AxisTitle { Text = "Außentemperatur (°C)" } },
            Yaxis = [new YAxis { Title = new AxisTitle { Text = "Leistung (kW)" }, Labels = new YAxisLabels { Formatter = @"function(val) { return val.toFixed(1); }" } }],
            Stroke = new Stroke { Width = new List<double> { 4, 3, 2 }, DashArray = new List<double> { 0, 0, 4 } },
            Colors = ["#7c3aed", "#dc2626", "#f97316"],
            Tooltip = new Tooltip { Enabled = true, Y = new TooltipY { Formatter = @"function(val) { return val.toFixed(1); }" } },
            Legend = new Legend { Position = LegendPosition.Bottom }
        };
        _dataChanged = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && _dataChanged && _chart != null)
        {
            _dataChanged = false;
            await _chart.RenderAsync();
        }
    }
}
