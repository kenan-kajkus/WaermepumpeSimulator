@using Microsoft.AspNetCore.Components.Forms

<header class="bg-white border-b border-gray-200 px-3 md:px-6 py-2 md:py-3 z-10">
    <!-- Row 1: Navigation & Actions -->
    <div class="flex items-center gap-2">
        <button class="md:hidden text-gray-600 hover:text-gray-800 p-2 -ml-1" @onclick="OnToggleSidebar" title="Parameter">
            <i class="fas fa-sliders text-lg"></i>
        </button>
        <h1 class="text-lg md:text-xl font-bold text-blue-700 whitespace-nowrap">
            WP Simulator
            <span class="text-sm font-normal text-gray-500 hidden md:inline">Jahresarbeitszahl & Taktung</span>
            <a href="/changelog" class="text-xs font-normal text-gray-400 hover:text-blue-500 ml-1" title="Changelog"><i class="fas fa-clock-rotate-left"></i></a>
            <a href="https://github.com/kenan-kajkus/WaermepumpeSimulator" target="_blank" rel="noopener noreferrer" class="text-xs font-normal text-gray-400 hover:text-gray-700 ml-1" title="GitHub"><i class="fab fa-github"></i></a>
        </h1>
        <div class="flex-1"></div>

        <div class="hidden lg:block text-xs text-right mx-2 leading-tight w-24">
            <div class="@StatusClass font-medium">@StatusText</div>
            <div class="text-[10px] text-gray-400">@StatusSub</div>
        </div>

        <button @onclick="OnRunSimulation" class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-3 md:px-6 rounded shadow-lg transition transform hover:scale-105 flex items-center gap-2 whitespace-nowrap">
            <i class="fas fa-calculator"></i>
            <span class="hidden sm:inline">BERECHNEN</span>
        </button>

        @if (ResultAvailable)
        {
            <button @onclick="OnAddToComparison" class="hidden sm:flex bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded shadow transition text-xs items-center gap-1 whitespace-nowrap" title="Aktuelles Ergebnis zum Vergleich hinzufügen">
                <i class="fas fa-plus"></i> Vergleich
            </button>
        }

        <button @onclick="OnShareConfig" class="hidden sm:flex bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded shadow transition text-xs items-center gap-1 whitespace-nowrap" title="Link mit aktueller Konfiguration kopieren">
            <i class="fas @(ShareCopied ? "fa-check" : "fa-share-nodes")"></i> @(ShareCopied ? "Kopiert!" : "Teilen")
        </button>
    </div>

    <!-- Row 2: Data Controls -->
    <div class="flex items-center gap-2 mt-2 flex-wrap">
        <div class="relative flex items-center">
            <span class="text-xs text-gray-500 mr-1 hidden sm:inline">Standort:</span>
            <select value="@SelectedCity" @onchange="HandleCityChange" class="border border-gray-300 rounded px-2 py-1.5 text-xs w-28 sm:w-32 focus:outline-none focus:border-blue-500 bg-white">
                @if (string.IsNullOrEmpty(SelectedCity))
                {
                    <option value="">— wählen —</option>
                }
                @foreach (var p in Profiles)
                {
                    <option value="@p.Key">@p.DisplayName</option>
                }
                @if (GeoLocationName != null)
                {
                    <option value="__geo__">@GeoLocationName</option>
                }
            </select>
            <button @onclick="OnUseMyLocation" class="bg-blue-50 hover:bg-blue-100 text-blue-600 py-1.5 px-2 rounded border border-blue-200 transition text-xs flex items-center gap-1" title="Meinen Standort verwenden" disabled="@GeoLoading">
                @if (GeoLoading)
                {
                    <i class="fas fa-spinner fa-spin"></i>
                }
                else
                {
                    <i class="fas fa-location-crosshairs"></i>
                }
            </button>
            <div class="flex items-center">
                <input type="text" @bind="_postalCode" @bind:event="oninput" @onkeydown="HandlePlzKeyDown"
                       placeholder="PLZ" maxlength="10"
                       class="border border-gray-300 rounded-l px-2 py-1.5 text-xs w-16 sm:w-20 focus:outline-none focus:border-blue-500 bg-white" />
                <button @onclick="HandlePlzSearch" class="bg-blue-50 hover:bg-blue-100 text-blue-600 py-1.5 px-2 rounded-r border border-l-0 border-blue-200 transition text-xs flex items-center" title="Postleitzahl suchen" disabled="@GeoLoading">
                    <i class="fas fa-magnifying-glass"></i>
                </button>
            </div>
            @if (GeoLatitude.HasValue && GeoLongitude.HasValue)
            {
                <a href="https://www.openstreetmap.org/?mlat=@(GeoLatitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture))&mlon=@(GeoLongitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture))#map=12/@(GeoLatitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture))/@(GeoLongitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                   target="_blank" class="hidden sm:flex bg-blue-50 hover:bg-blue-100 text-blue-600 py-1.5 px-2 rounded border border-blue-200 transition text-xs items-center gap-1" title="Standort auf OpenStreetMap anzeigen">
                    <i class="fas fa-map-location-dot"></i>
                </a>
            }
        </div>

        @if (AvailableYears.Count > 0)
        {
            <div class="relative flex items-center">
                <span class="text-xs text-gray-500 mr-1 hidden sm:inline">Jahr:</span>
                <select value="@SelectedYear" @onchange="HandleYearChange" disabled="@(AvailableYears.Count <= 1)" class="border border-gray-300 rounded px-2 py-1.5 text-xs w-20 sm:w-24 focus:outline-none focus:border-blue-500 bg-white">
                    @if (AvailableYears.Count > 1)
                    {
                        <option value="all">Alle</option>
                    }
                    @foreach (var y in AvailableYears.OrderBy(x => x))
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>
        }

        <div class="hidden md:flex items-center gap-2">
            <div class="relative flex items-center">
                <span class="text-xs text-gray-500 mr-1">Von:</span>
                <input type="date" value="@StartDate.ToString("yyyy-MM-dd")" @onchange="HandleStartDateChange" class="border border-gray-300 rounded px-1 py-1 text-xs focus:outline-none focus:border-blue-500 bg-white" />
            </div>
            <div class="relative flex items-center">
                <span class="text-xs text-gray-500 mr-1">Bis:</span>
                <input type="date" value="@EndDate.ToString("yyyy-MM-dd")" @onchange="HandleEndDateChange" class="border border-gray-300 rounded px-1 py-1 text-xs focus:outline-none focus:border-blue-500 bg-white" />
            </div>
        </div>

        <label class="hidden md:flex bg-gray-100 hover:bg-gray-200 text-gray-600 cursor-pointer py-1.5 px-3 rounded border border-gray-300 transition text-xs items-center gap-2 relative group" title="Eigene CSV Datei hochladen">
            <i class="fas fa-upload"></i> CSV
            <InputFile OnChange="OnCsvUpload" accept=".csv" class="hidden" />
            <div class="invisible group-hover:visible absolute top-full left-0 mt-1 w-72 bg-gray-800 text-white text-xs rounded-lg shadow-lg p-3 z-50 leading-relaxed">
                <div class="font-bold mb-1">CSV-Format (kommagetrennt):</div>
                <div class="font-mono bg-gray-900 rounded p-1.5 mb-1.5 text-[10px]">
                    time,temperature_2m,relative_humidity_2m<br/>
                    2023-01-01T00:00,-2.1,89<br/>
                    2023-01-01T01:00,-2.5,91<br/>
                    ...
                </div>
                <div><b>Spalten:</b> date/time, temp/t2m (&deg;C), rh/humidity (%)</div>
                <div class="text-gray-400 mt-1">Feuchte ist optional. Min. 100 st&uuml;ndliche Datenpunkte. Open-Meteo Export wird direkt unterst&uuml;tzt.</div>
            </div>
        </label>
    </div>
</header>

@code {
    [Parameter] public string SelectedCity { get; set; } = "";
    [Parameter] public List<ClimateProfile> Profiles { get; set; } = [];
    [Parameter] public HashSet<int> AvailableYears { get; set; } = [];
    [Parameter] public string SelectedYear { get; set; } = "";
    [Parameter] public string? GeoLocationName { get; set; }
    [Parameter] public double? GeoLatitude { get; set; }
    [Parameter] public double? GeoLongitude { get; set; }
    [Parameter] public bool GeoLoading { get; set; }
    [Parameter] public string StatusText { get; set; } = "";
    [Parameter] public string StatusSub { get; set; } = "";
    [Parameter] public string StatusClass { get; set; } = "";
    [Parameter] public DateTime StartDate { get; set; }
    [Parameter] public DateTime EndDate { get; set; }
    [Parameter] public bool ResultAvailable { get; set; }
    [Parameter] public bool ShareCopied { get; set; }

    [Parameter] public EventCallback<string> OnCitySelected { get; set; }
    [Parameter] public EventCallback OnUseMyLocation { get; set; }
    [Parameter] public EventCallback<string> OnPostalCodeSearch { get; set; }
    [Parameter] public EventCallback<string> OnYearSelected { get; set; }
    [Parameter] public EventCallback<DateTime> OnStartDateChanged { get; set; }
    [Parameter] public EventCallback<DateTime> OnEndDateChanged { get; set; }
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnCsvUpload { get; set; }
    [Parameter] public EventCallback OnRunSimulation { get; set; }
    [Parameter] public EventCallback OnAddToComparison { get; set; }
    [Parameter] public EventCallback OnShareConfig { get; set; }
    [Parameter] public EventCallback OnToggleSidebar { get; set; }

    private string _postalCode = "";

    private async Task HandlePlzSearch()
    {
        if (!string.IsNullOrWhiteSpace(_postalCode))
            await OnPostalCodeSearch.InvokeAsync(_postalCode.Trim());
    }

    private async Task HandlePlzKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandlePlzSearch();
    }

    private async Task HandleCityChange(ChangeEventArgs e)
    {
        await OnCitySelected.InvokeAsync(e.Value?.ToString() ?? "");
    }

    private async Task HandleYearChange(ChangeEventArgs e)
    {
        await OnYearSelected.InvokeAsync(e.Value?.ToString() ?? "");
    }

    private async Task HandleStartDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
            await OnStartDateChanged.InvokeAsync(date);
    }

    private async Task HandleEndDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
            await OnEndDateChanged.InvokeAsync(date);
    }
}
