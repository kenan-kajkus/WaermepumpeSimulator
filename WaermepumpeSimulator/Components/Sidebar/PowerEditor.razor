@* Structured power data editor with sorted rows and tab-to-add *@

<div class="input-group">
    <label class="input-label">@Label <i class="fas fa-circle-question help-icon"></i></label>
    <span class="tooltip">@((MarkupString)Tooltip)</span>

    @if (!string.IsNullOrEmpty(ErrorText))
    {
        <span class="text-[10px] text-red-500 mb-1 block">@ErrorText</span>
    }
    else if (!string.IsNullOrEmpty(WarningText))
    {
        <span class="text-[10px] text-orange-500 mb-1 block">@WarningText</span>
    }

    <div class="grid grid-cols-[1fr_1fr_1.25rem] gap-0.5 items-center text-[10px] font-semibold text-gray-500 mb-0.5">
        <span>AT (°C)</span>
        <span>kW</span>
        <span></span>
    </div>

    @for (int idx = 0; idx < _rows.Count; idx++)
    {
        var i = idx;
        var empty = IsRowEmpty(_rows[i]);
        <div class="grid grid-cols-[1fr_1fr_1.25rem] gap-0.5 items-center mb-0.5">
            <input type="text" inputmode="decimal" value="@_rows[i].Temp"
                   @onchange="e => OnFieldChanged(i, 0, e)"
                   @oninput="OnInput"
                   placeholder="@(empty ? "°C" : "")"
                   class="cop-cell @(empty ? "cop-cell-empty" : "") @(!empty && HasError ? "!border-red-400" : !empty && HasWarning ? "!border-orange-400" : "")" />
            <input type="text" inputmode="decimal" value="@_rows[i].Value"
                   @onchange="e => OnFieldChanged(i, 1, e)"
                   @oninput="OnInput"
                   placeholder="@(empty ? "kW" : "")"
                   class="cop-cell @(empty ? "cop-cell-empty" : "") @(!empty && HasError ? "!border-red-400" : !empty && HasWarning ? "!border-orange-400" : "")" />
            @if (!empty)
            {
                <button tabindex="-1" @onclick="() => RemoveRow(i)" class="text-gray-400 hover:text-red-500 text-xs leading-none" title="Zeile entfernen">
                    <i class="fas fa-xmark"></i>
                </button>
            }
            else
            {
                <span></span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback OnInput { get; set; }
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Tooltip { get; set; } = "";
    [Parameter] public bool HasError { get; set; }
    [Parameter] public bool HasWarning { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? WarningText { get; set; }

    private List<PowerRow> _rows = [];
    private string? _lastSerialized;

    private class PowerRow
    {
        public string Temp { get; set; } = "";
        public string Value { get; set; } = "";
    }

    private static bool IsRowEmpty(PowerRow r)
        => string.IsNullOrWhiteSpace(r.Temp) && string.IsNullOrWhiteSpace(r.Value);

    protected override void OnParametersSet()
    {
        if (Value != _lastSerialized)
        {
            _rows = ParseRows(Value);
            SortRows();
            EnsureSentinel();
            _lastSerialized = Value;
        }
    }

    private static List<PowerRow> ParseRows(string text)
    {
        var seen = new Dictionary<double, int>();
        var rows = new List<PowerRow>();
        if (string.IsNullOrWhiteSpace(text)) return rows;
        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = line.Split(',');
            if (parts.Length >= 2)
            {
                var row = new PowerRow { Temp = parts[0].Trim(), Value = parts[1].Trim() };
                // Deduplicate: last value for a given temperature wins
                if (double.TryParse(row.Temp, System.Globalization.NumberStyles.Float,
                        System.Globalization.CultureInfo.InvariantCulture, out var temp))
                {
                    if (seen.TryGetValue(temp, out var existingIdx))
                    {
                        rows[existingIdx] = row;
                        continue;
                    }
                    seen[temp] = rows.Count;
                }
                rows.Add(row);
            }
        }
        return rows;
    }

    private void SortRows()
    {
        _rows = _rows
            .Where(r => !IsRowEmpty(r))
            .OrderBy(r => double.TryParse(r.Temp, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : double.MaxValue)
            .ToList();
    }

    private void EnsureSentinel()
    {
        if (_rows.Count == 0 || !IsRowEmpty(_rows[^1]))
            _rows.Add(new PowerRow());
    }

    private string Serialize()
    {
        var dataRows = _rows.Where(r => !IsRowEmpty(r)).ToList();
        dataRows.Sort((a, b) =>
        {
            double.TryParse(a.Temp, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var av);
            double.TryParse(b.Temp, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var bv);
            return av.CompareTo(bv);
        });
        return string.Join("\n", dataRows.Select(r => $"{r.Temp}, {r.Value}"));
    }

    private async Task EmitChange()
    {
        EnsureSentinel();
        _lastSerialized = Serialize();
        await ValueChanged.InvokeAsync(_lastSerialized);
    }

    private async Task OnFieldChanged(int row, int field, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        if (field == 0) _rows[row].Temp = val;
        else _rows[row].Value = val;

        // Enforce unique temperatures: if another row has the same temp, remove it
        if (field == 0 && double.TryParse(val, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var newTemp))
        {
            for (int j = _rows.Count - 1; j >= 0; j--)
            {
                if (j == row || IsRowEmpty(_rows[j])) continue;
                if (double.TryParse(_rows[j].Temp, System.Globalization.NumberStyles.Float,
                        System.Globalization.CultureInfo.InvariantCulture, out var existingTemp)
                    && Math.Abs(existingTemp - newTemp) < 0.001)
                {
                    _rows.RemoveAt(j);
                    if (j < row) row--;
                    break;
                }
            }
        }

        await EmitChange();
    }

    private async Task RemoveRow(int index)
    {
        _rows.RemoveAt(index);
        EnsureSentinel();
        await EmitChange();
    }
}
