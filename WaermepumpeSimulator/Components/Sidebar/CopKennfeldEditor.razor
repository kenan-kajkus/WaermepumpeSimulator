@* Structured COP Kennfeld editor with tab-to-add, collapsible, VL chips, manual reorder *@

<div class="input-group">
    <div class="flex items-center cursor-pointer select-none" @onclick="() => _collapsed = !_collapsed">
        <i class="fas @(_collapsed ? "fa-chevron-right" : "fa-chevron-down") text-[10px] text-gray-400 mr-1.5 w-3"></i>
        <label class="input-label mb-0 cursor-pointer">COP Kennfeld</label>
        <span class="ml-1.5 text-[10px] text-gray-400 font-normal">(@DataRowCount)</span>
        <i class="fas fa-circle-question help-icon"></i>
    </div>
    <span class="tooltip">COP-Daten der Wärmepumpe.<br>VL = Vorlauftemperatur, AT = Außentemperatur.<br>COP PMin ist optional – wenn leer, gilt COP für alle Leistungsstufen.</span>

    @if (!_collapsed)
    {
        @if (HasError)
        {
            <span class="text-[10px] text-red-500 mb-1 block mt-1">Mind. 2 COP-Datenpunkte</span>
        }
        else if (HasWarning)
        {
            <span class="text-[10px] text-orange-500 mb-1 block mt-1">COP-Werte sollten zwischen 0.5 und 15 liegen</span>
        }

        <!-- VL quick-select chips -->
        <div class="flex items-center gap-1 mt-1 mb-1.5">
            <span class="text-[10px] text-gray-400">VL Zeile:</span>
            @foreach (var vl in _vlPresets)
            {
                var v = vl;
                <button tabindex="-1" @onclick="() => AddRowWithVL(v)"
                        class="text-[10px] px-2 py-0.5 rounded-full border transition
                               @(HasVL(v) ? "bg-blue-100 border-blue-300 text-blue-700" : "bg-gray-50 border-gray-300 text-gray-500 hover:bg-blue-50 hover:border-blue-200")">
                    W@(v)
                </button>
            }
        </div>

        <div class="grid grid-cols-[3rem_3rem_1fr_1fr_1.5rem_1.25rem] gap-0.5 items-center text-[10px] font-semibold text-gray-500 mb-0.5">
            <span>VL</span>
            <span>AT</span>
            <span>COP</span>
            <span>COP min</span>
            <span></span>
            <span></span>
        </div>

        @for (int idx = 0; idx < _rows.Count; idx++)
        {
            var i = idx;
            var empty = IsRowEmpty(_rows[i]);
            <div class="grid grid-cols-[3rem_3rem_1fr_1fr_1.5rem_1.25rem] gap-0.5 items-center mb-0.5">
                <input type="text" inputmode="decimal" value="@_rows[i].VL"
                       @onchange="e => OnFieldChanged(i, 0, e)"
                       @oninput="OnInput"
                       placeholder="@(empty ? "VL" : "")"
                       class="cop-cell @(empty ? "cop-cell-empty" : "") @(!empty && HasError ? "!border-red-400" : !empty && HasWarning ? "!border-orange-400" : "")" />
                <input type="text" inputmode="decimal" value="@_rows[i].AT"
                       @onchange="e => OnFieldChanged(i, 1, e)"
                       @oninput="OnInput"
                       placeholder="@(empty ? "AT" : "")"
                       class="cop-cell @(empty ? "cop-cell-empty" : "") @(!empty && HasError ? "!border-red-400" : !empty && HasWarning ? "!border-orange-400" : "")" />
                <input type="text" inputmode="decimal" value="@_rows[i].CopPMax"
                       @onchange="e => OnFieldChanged(i, 2, e)"
                       @oninput="OnInput"
                       placeholder="@(empty ? "COP" : "")"
                       class="cop-cell @(empty ? "cop-cell-empty" : "") @(!empty && HasError ? "!border-red-400" : !empty && HasWarning ? "!border-orange-400" : "")" />
                <input type="text" inputmode="decimal" value="@_rows[i].CopPMin"
                       @onchange="e => OnFieldChanged(i, 3, e)"
                       @oninput="OnInput"
                       placeholder="@(empty ? "COP min" : "")"
                       class="cop-cell @(empty ? "cop-cell-empty" : "")" />
                @if (!empty)
                {
                    <div class="flex flex-col items-center leading-none">
                        <button tabindex="-1" @onclick="() => MoveRow(i, -1)" disabled="@(i == 0)" class="text-gray-300 hover:text-gray-600 disabled:opacity-20 disabled:pointer-events-none text-[8px]" title="Nach oben">
                            <i class="fas fa-caret-up"></i>
                        </button>
                        <button tabindex="-1" @onclick="() => MoveRow(i, 1)" disabled="@(i >= _rows.Count - 2)" class="text-gray-300 hover:text-gray-600 disabled:opacity-20 disabled:pointer-events-none text-[8px]" title="Nach unten">
                            <i class="fas fa-caret-down"></i>
                        </button>
                    </div>
                    <button tabindex="-1" @onclick="() => RemoveRow(i)" class="text-gray-400 hover:text-red-500 text-xs leading-none" title="Zeile entfernen">
                        <i class="fas fa-xmark"></i>
                    </button>
                }
                else
                {
                    <span></span>
                    <span></span>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback OnInput { get; set; }
    [Parameter] public bool HasError { get; set; }
    [Parameter] public bool HasWarning { get; set; }

    private List<CopRow> _rows = [];
    private string? _lastSerialized;
    private bool _collapsed;
    private static readonly string[] _vlPresets = ["35", "55"];

    private int DataRowCount => _rows.Count(r => !IsRowEmpty(r));

    private bool HasVL(string vl) => _rows.Any(r => !IsRowEmpty(r) && r.VL == vl);

    private class CopRow
    {
        public string VL { get; set; } = "";
        public string AT { get; set; } = "";
        public string CopPMax { get; set; } = "";
        public string CopPMin { get; set; } = "";
    }

    private static bool IsRowEmpty(CopRow r)
        => string.IsNullOrWhiteSpace(r.VL) && string.IsNullOrWhiteSpace(r.AT)
           && string.IsNullOrWhiteSpace(r.CopPMax) && string.IsNullOrWhiteSpace(r.CopPMin);

    protected override void OnParametersSet()
    {
        if (Value != _lastSerialized)
        {
            _rows = ParseRows(Value);
            EnsureSentinel();
            _lastSerialized = Value;
        }
    }

    private static List<CopRow> ParseRows(string text)
    {
        var rows = new List<CopRow>();
        if (string.IsNullOrWhiteSpace(text)) return rows;
        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = line.Split(',');
            if (parts.Length >= 3)
            {
                rows.Add(new CopRow
                {
                    VL = parts[0].Trim(),
                    AT = parts[1].Trim(),
                    CopPMax = parts[2].Trim(),
                    CopPMin = parts.Length >= 4 ? parts[3].Trim() : ""
                });
            }
        }
        return rows;
    }

    private void EnsureSentinel()
    {
        if (_rows.Count == 0 || !IsRowEmpty(_rows[^1]))
            _rows.Add(new CopRow());
    }

    private string Serialize()
    {
        return string.Join("\n", _rows.Where(r => !IsRowEmpty(r)).Select(r =>
        {
            var line = $"{r.VL}, {r.AT}, {r.CopPMax}";
            if (!string.IsNullOrWhiteSpace(r.CopPMin))
                line += $", {r.CopPMin}";
            return line;
        }));
    }

    private async Task EmitChange()
    {
        EnsureSentinel();
        _lastSerialized = Serialize();
        await ValueChanged.InvokeAsync(_lastSerialized);
    }

    private async Task OnFieldChanged(int row, int field, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        switch (field)
        {
            case 0: _rows[row].VL = val; break;
            case 1: _rows[row].AT = val; break;
            case 2: _rows[row].CopPMax = val; break;
            case 3: _rows[row].CopPMin = val; break;
        }
        await EmitChange();
    }

    private async Task AddRowWithVL(string vl)
    {
        int insertIdx = _rows.Count > 0 && IsRowEmpty(_rows[^1]) ? _rows.Count - 1 : _rows.Count;
        _rows.Insert(insertIdx, new CopRow { VL = vl });
        await EmitChange();
    }

    private async Task MoveRow(int index, int direction)
    {
        int target = index + direction;
        if (target < 0 || target >= _rows.Count) return;
        if (IsRowEmpty(_rows[target])) return;
        (_rows[index], _rows[target]) = (_rows[target], _rows[index]);
        await EmitChange();
    }

    private async Task RemoveRow(int index)
    {
        _rows.RemoveAt(index);
        EnsureSentinel();
        await EmitChange();
    }
}
