@page "/"

<PageTitle>WP Simulator & JAZ Rechner</PageTitle>

@if (_initializing)
{
    <div class="flex items-center justify-center h-screen">
        <div class="text-center">
            <div style="width:40px;height:40px;margin:0 auto 1rem;border:3px solid #f3f3f3;border-top:3px solid #3498db;border-radius:50%;animation:spin 1s linear infinite;"></div>
            <p class="text-gray-500">Lade Simulator...</p>
        </div>
    </div>
}
else
{

<div class="flex flex-col h-screen overflow-hidden">
    <HeaderBar SelectedCity="@_selectedCity"
               Profiles="@_profiles"
               AvailableYears="@_availableYears"
               SelectedYear="@_selectedYear"
               GeoLocationName="@_geoLocationName"
               GeoLatitude="@_geoLatitude"
               GeoLongitude="@_geoLongitude"
               GeoLoading="@_geoLoading"
               StatusText="@_statusText"
               StatusSub="@_statusSub"
               StatusClass="@_statusClass"
               StartDate="@_startDate"
               EndDate="@_endDate"
               ResultAvailable="@(_result != null)"
               ShareCopied="@_shareCopied"
               OnCitySelected="HandleCitySelected"
               OnUseMyLocation="UseMyLocation"
               OnYearSelected="HandleYearSelected"
               OnStartDateChanged="@((DateTime d) => _startDate = d)"
               OnEndDateChanged="@((DateTime d) => _endDate = d)"
               OnCsvUpload="OnCsvUpload"
               OnRunSimulation="RunSimulation"
               OnAddToComparison="AddToComparison"
               OnShareConfig="ShareConfig"
               OnToggleSidebar="ToggleSidebar" />

    <div class="flex flex-1 overflow-hidden">
        @if (_sidebarOpen)
        {
            <div class="fixed inset-0 bg-black/50 z-30 md:hidden" @onclick="ToggleSidebar"></div>
        }
        <div class="fixed inset-y-0 left-0 z-40 transition-transform duration-200
                    @(_sidebarOpen ? "translate-x-0" : "-translate-x-full")
                    md:static md:translate-x-0 md:z-0 md:transition-none">
            <SidebarPanel Params="@Params"
                          Validation="@GetValidationState()"
                          SelectedPreset="@_selectedPreset"
                          Presets="@_presets"
                          CustomPresets="@_customPresets"
                          UndoCount="@_undoStack.Count"
                          RedoCount="@_redoStack.Count"
                          OnParamChanged="OnParamChanged"
                          OnPresetSelected="HandlePresetSelected"
                          OnResetPreset="HandleResetPreset"
                          OnSaveCustomPreset="SaveCustomPreset"
                          OnRenameCustomPreset="RenameCustomPreset"
                          OnDeleteCustomPreset="DeleteCustomPreset"
                          OnSaveKennfeld="SaveKennfeld"
                          OnLoadKennfeld="LoadKennfeld"
                          OnUndo="Undo"
                          OnRedo="Redo"
                          OnResetToDefaults="ResetToDefaults"
                          OnClose="ToggleSidebar" />
        </div>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto bg-gray-50 p-3 md:p-6">
            @if (HasValidationErrors())
            {
                <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg flex items-center gap-2 text-sm text-red-700 no-print">
                    <i class="fas fa-triangle-exclamation"></i>
                    <span>Eingabefehler in der Seitenleiste beheben, um die Simulation zu starten.</span>
                </div>
            }
            @if (_comparisonEntries.Count > 0)
            {
                <ComparisonTable Entries="@_comparisonEntries"
                                 OnRemoveEntry="RemoveComparison"
                                 OnClearAll="ClearComparison"
                                 OnExportCsv="ExportComparisonCsv" />
            }

            @if (_result != null)
            {
                <div class="@(_simulating ? "opacity-40 pointer-events-none" : "opacity-100") transition-opacity duration-200">

                <!-- Verdict Banner -->
                <div class="mb-8 p-4 rounded-lg shadow-md border-l-8 bg-white flex flex-col justify-center">
                    <div class="flex items-center justify-between">
                        <div class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-1">Gesamtfazit der Auslegung</div>
                        <div class="flex items-center gap-2 no-print">
                            <button @onclick="ExportSummaryCsv" class="text-xs text-blue-500 hover:text-blue-700 flex items-center gap-1" title="Zusammenfassung als CSV">
                                <i class="fas fa-file-csv"></i> Zusammenfassung
                            </button>
                            <button @onclick="ExportHourlyCsv" class="text-xs text-blue-500 hover:text-blue-700 flex items-center gap-1" title="Stündliche Daten als CSV (8760 Zeilen)">
                                <i class="fas fa-table"></i> Stundenwerte
                            </button>
                            <button @onclick="PrintPage" class="text-xs text-blue-500 hover:text-blue-700 flex items-center gap-1" title="Ergebnisse drucken / als PDF speichern">
                                <i class="fas fa-file-pdf"></i> PDF
                            </button>
                        </div>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-800">Analyse abgeschlossen</h2>
                    @if (_eval != null)
                    {
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-2 text-sm">
                            <div class="@GetBgClass(_eval.JazColor) p-3 rounded border @GetBorderClass(_eval.JazColor)">
                                <p class="font-bold @GetTextClass(_eval.JazColor) uppercase text-[10px] mb-1">Effizienz (JAZ)</p>
                                <div class="text-2xl font-black text-gray-800 mb-1">@_result.Jaz.ToString("F2")</div>
                                <p class="text-[11px] text-gray-700 leading-snug">@_eval.JazText</p>
                            </div>
                            <div class="@GetBgClass(_eval.TaktColor) p-3 rounded border @GetBorderClass(_eval.TaktColor)">
                                <p class="font-bold @GetTextClass(_eval.TaktColor) uppercase text-[10px] mb-1">Takt-Check</p>
                                <div class="text-2xl font-black text-gray-800 mb-1">@_result.CyclingPercent.ToString("F1") %</div>
                                <p class="text-[11px] text-gray-700 leading-snug">@_eval.TaktText</p>
                            </div>
                            <div class="@GetBgClass(_eval.StabColor) p-3 rounded border @GetBorderClass(_eval.StabColor)">
                                <p class="font-bold @GetTextClass(_eval.StabColor) uppercase text-[10px] mb-1">Auslegung & Heizstab</p>
                                <div class="text-2xl font-black text-gray-800 mb-1">@_result.HeizstabShare.ToString("F1") % <span class="text-sm font-normal text-gray-500">p.a.</span></div>
                                <p class="text-[11px] text-gray-700 leading-snug">@((MarkupString)_eval.StabText)</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Section 1: Härtetest -->
                <div class="mb-10">
                    <h2 class="text-xl font-bold text-gray-800 border-b-2 border-indigo-200 pb-2 mb-3 flex items-center gap-2">
                        <i class="fas fa-snowflake text-indigo-500"></i> 1. Der Härtetest (Theoretische Auslegung)
                    </h2>
                    <p class="text-sm text-gray-600 mb-4">
                        Schafft die WP es am kältesten Tag (NAT: <span class="font-bold">@Params.NormAussentemperatur °C</span>) dein Haus warm zu halten?
                    </p>
                    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                        <div class="xl:col-span-1 flex flex-col justify-center">
                            <div class="bg-white p-6 rounded-lg shadow border-l-4 border-indigo-500 h-full flex flex-col justify-center">
                                <div class="space-y-5 text-sm text-gray-700">
                                    <div>
                                        <div class="text-gray-500 mb-1">Heizlast Haus (@@NAT):</div>
                                        <div class="font-bold text-purple-700 text-2xl">@_result.LoadAtDesignTemp.ToString("F1") kW</div>
                                    </div>
                                    <div>
                                        <div class="text-gray-500 mb-1">Max. Leistung WP (@@NAT):</div>
                                        <div class="font-bold @(_result.HeatPumpPowerAtDesignTemp >= _result.LoadAtDesignTemp ? "text-green-600" : _result.HeatPumpPowerAtDesignTemp + Params.HeizstabMax >= _result.LoadAtDesignTemp ? "text-orange-500" : "text-red-600") text-2xl">@_result.HeatPumpPowerAtDesignTemp.ToString("F1") kW</div>
                                    </div>
                                    <div class="border-t border-gray-100 pt-4 mt-2">
                                        <div class="text-[11px] text-gray-500 uppercase font-bold mb-1">Bivalenzpunkt</div>
                                        <div class="font-medium text-gray-800 mb-1">Heizstab-Einsatz nötig ab:</div>
                                        <div class="font-bold text-red-600 text-3xl">@(_result.BivalenceTemperature.HasValue ? $"{_result.BivalenceTemperature:F1} °C" : "Keiner")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="xl:col-span-2">
                            <div class="bg-white p-4 rounded-lg shadow h-full">
                                <h4 class="font-bold text-gray-700 mb-2 italic text-sm">Leistung vs. Heizlast</h4>
                                <DesignChart Result="_result" HeizstabMax="Params.HeizstabMax" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Jahressimulation KPIs -->
                <div class="mb-10">
                    <h2 class="text-xl font-bold text-gray-800 border-b-2 border-blue-200 pb-2 mb-3 flex items-center gap-2">
                        <i class="fas fa-calendar-alt text-blue-500"></i> 2. Jahressimulation (Realer Alltag)
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        <div class="bg-white p-4 rounded shadow border-t-4 border-blue-500 flex flex-col">
                            <div class="text-xs text-gray-500 uppercase font-bold mb-1">Effizienz (JAZ)</div>
                            <div class="text-3xl font-black text-blue-600">@_result.Jaz.ToString("F3")</div>
                            <div class="text-xs text-gray-400 mt-auto pt-2">Verhältnis von gewonnener Wärme zu eingesetztem Strom.</div>
                        </div>
                        <div class="bg-white p-4 rounded shadow border-t-4 border-orange-500 flex flex-col">
                            <div class="text-xs text-gray-500 uppercase font-bold mb-1">Stromverbrauch p.a.</div>
                            <div class="text-3xl font-black text-gray-800">@Math.Round(_result.TotalElectricity) <span class="text-base font-normal text-gray-500">kWh</span></div>
                            <div class="flex justify-between text-[11px] mt-auto pt-2 border-t border-gray-100">
                                <span class="text-gray-400">Heizstab-Anteil:</span>
                                <span class="font-bold text-red-500">@_result.HeizstabShare.ToString("F1")%</span>
                            </div>
                        </div>
                        <div class="bg-white p-4 rounded shadow border-t-4 border-green-500 flex flex-col">
                            <div class="text-xs text-gray-500 uppercase font-bold mb-1">Finanzen (Ersparnis)</div>
                            <div class="@(_result.Savings > 0 ? "text-green-600" : "text-red-600") text-2xl font-black leading-none mb-2">
                                @(_result.Savings > 0 ? $"Ersparnis: {Math.Round(_result.Savings)} €/Jahr" : $"Mehrkosten: {Math.Round(Math.Abs(_result.Savings))} €/Jahr")
                            </div>
                            <div class="text-[11px] text-gray-500 space-y-1 mt-auto border-t border-gray-100 pt-2">
                                <div class="flex justify-between"><span>Alte Heizung:</span><span class="font-semibold">@Math.Round(_result.CostOldHeating) €</span></div>
                                <div class="flex justify-between"><span>Neu (WP):</span><span class="font-semibold text-blue-600">@Math.Round(_result.CostHeatPump) €</span></div>
                            </div>
                        </div>
                        <div class="bg-white p-4 rounded shadow border-t-4 border-yellow-400 flex flex-col">
                            <div class="text-xs text-yellow-600 uppercase font-bold mb-1 flex items-center gap-1"><i class="fas fa-stopwatch"></i> Taktgefahr</div>
                            <div class="text-3xl font-black text-gray-800">@_result.CyclingPercent.ToString("F1") %</div>
                            <div class="text-xs text-gray-400 mt-auto pt-2">% der aktiven Heizzeit unter Minimalleistung.</div>
                        </div>
                        <div class="bg-white p-4 rounded shadow border-t-4 border-cyan-400 flex flex-col relative overflow-hidden">
                            <div class="absolute -right-2 -top-4 opacity-10 text-cyan-500 text-7xl"><i class="fas fa-icicles"></i></div>
                            <div class="text-xs text-cyan-700 uppercase font-bold mb-1 flex items-center gap-1"><i class="fas fa-snowflake"></i> Abtau-Risiko</div>
                            <div class="text-3xl font-black text-gray-800 relative z-10">@_result.IcingHours <span class="text-base font-normal text-gray-500">Stunden</span></div>
                            <div class="text-xs text-gray-500 mt-auto pt-2 relative z-10">Kritische Wetterbedingungen um 0°C & feucht.</div>
                        </div>
                        <div class="bg-white p-4 rounded shadow border-t-4 border-red-400 flex flex-col">
                            <div class="text-xs text-red-600 uppercase font-bold mb-1 flex items-center gap-1"><i class="fas fa-exclamation-triangle"></i> Ungedeckter Bedarf</div>
                            <div class="text-xl font-bold text-gray-800">@(_result.DeficitHours > 0 ? $"{_result.DeficitHours}h ({Math.Round(_result.DeficitKwh)} kWh fehlen)" : "Ausreichend")</div>
                            <div class="text-xs text-gray-400 mt-auto pt-2">Stunden, in denen weder WP noch Heizstab das Haus warmhalten konnten.</div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Detail Charts -->
                <div class="mb-4">
                    <h2 class="text-xl font-bold text-gray-800 border-b-2 border-gray-200 pb-2 mb-3 flex items-center gap-2">
                        <i class="fas fa-chart-line text-gray-500"></i> 3. Detail-Auswertungen
                    </h2>
                    <div class="flex border-b border-gray-200 mb-6 bg-white rounded-t shadow-sm overflow-x-auto">
                        @foreach (var tab in _tabs)
                        {
                            <button class="tab-btn @(tab.Key == _activeTab ? "active" : "") whitespace-nowrap" @onclick="() => _activeTab = tab.Key">@tab.Value</button>
                        }
                    </div>

                    @if (_activeTab == "dashboard")
                    {
                        <div class="chart-container">
                            <h4 class="font-bold text-gray-700 mb-2 italic text-sm">Grafik: Reale Jahressimulation</h4>
                            <EfficiencyChart Result="_result" />
                            <p class="text-[10px] text-gray-500 mt-2">Punkte nach COP-Bereichen eingefärbt. Grün/Cyan = sehr sparsam.</p>
                        </div>
                        <div class="chart-container">
                            <DurationChart Result="_result" />
                        </div>
                    }
                    else if (_activeTab == "details")
                    {
                        <div class="chart-container">
                            <TemperatureChart Result="_result" />
                        </div>
                        <div class="chart-container">
                            <PowerChart Result="_result" />
                        </div>
                    }
                    else if (_activeTab == "icing")
                    {
                        <div class="chart-container">
                            <IcingMapChart Result="_result" />
                        </div>
                        <div class="chart-container">
                            <IcingZoomChart Result="_result" />
                        </div>
                    }
                    else if (_activeTab == "monthly")
                    {
                        <div class="chart-container">
                            <MonthlyChart Monthly="_monthly" />
                        </div>
                        <div class="bg-white rounded shadow overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200 text-sm">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Monat</th>
                                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Wärme (kWh)</th>
                                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Strom (kWh)</th>
                                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">JAZ</th>
                                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Kosten</th>
                                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Abtauungen</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    @if (_monthly != null)
                                    {
                                        @foreach (var m in _monthly)
                                        {
                                            <tr>
                                                <td class="px-6 py-2">@m.Name</td>
                                                <td class="px-6 py-2 text-right">@Math.Round(m.Waerme)</td>
                                                <td class="px-6 py-2 text-right">@Math.Round(m.Strom)</td>
                                                <td class="px-6 py-2 text-right font-bold text-blue-600">@(m.Strom > 0 ? m.Jaz.ToString("F2") : "-")</td>
                                                <td class="px-6 py-2 text-right">@m.Kosten.ToString("F0") €</td>
                                                <td class="px-6 py-2 text-right text-red-500">@m.IcingCount</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (_activeTab == "check")
                    {
                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                            <div class="chart-container"><CheckPowerChart Result="_result" /></div>
                            <div class="chart-container"><CheckCopChart Result="_result" /></div>
                            <div class="chart-container"><CheckEtaChart Result="_result" /></div>
                        </div>
                    }
                </div>

                <!-- Disclaimer -->
                <div class="mt-10 border-t border-gray-200 pt-6">
                    <details class="group bg-white border border-gray-200 rounded-lg shadow-sm">
                        <summary class="flex justify-between items-center font-medium cursor-pointer list-none p-4 text-gray-600 hover:bg-gray-50 transition">
                            <span class="flex items-center gap-2">
                                <i class="fas fa-circle-info text-blue-400"></i>
                                Wichtige Hinweise zu Genauigkeit & Grenzen der Simulation
                            </span>
                            <span class="transition group-open:rotate-180"><i class="fas fa-chevron-down"></i></span>
                        </summary>
                        <div class="text-xs text-gray-500 p-4 border-t border-gray-100 bg-gray-50 text-center">
                            <p class="font-semibold text-gray-600">Haftungsausschluss: Dieses Tool dient der groben Abschätzung. Es ersetzt keine professionelle Heizlastberechnung nach DIN EN 12831. Alle Ergebnisse ohne Gewähr.</p>
                        </div>
                    </details>
                </div>
                </div>
            }
            else
            {
                <div class="flex items-center justify-center h-64">
                    <div class="text-center text-gray-400">
                        <i class="fas fa-calculator text-4xl mb-3"></i>
                        <p>Wähle einen <b>Standort</b> um die Simulation zu starten.</p>
                    </div>
                </div>
            }
        </main>
    </div>
</div>

}
